{
  "packages": [
    "costrict-config",
    "cotun-options",
    "completion-config",
    "tokenizer-config",
    "hidden-scores-config",
    "system",
    "codebase-indexer",
    "apisix",
    "firmware",
    "backend",
    "casdoor",
    "chat-rag",
    "code-completion",
    "codebase-embedder",
    "codebase-querier",
    "codereview",
    "credit-manager",
    "client-manager",
    "etcd",
    "frontend",
    "monitoring",
    "oneapi",
    "portal",
    "costrict-admin-frontend",
    "costrict-admin-backend",
    "postgres",
    "quota-manager",
    "redis",
    "weaviate",
    "smc",
    "completion-agent",
    "cotun",
    "costrict",
    "costrict-admin"
  ],
  "builds": [
    {
      "name": "smc",
      "type": "exec",
      "path": "../smc",
      "version": "1.1.12",
      "platforms": [
        {
          "os": "windows",
          "arch": "amd64"
        },
        {
          "os": "linux",
          "arch": "amd64"
        }
      ],
      "description": "System management console"
    },
    {
      "name": "costrict",
      "type": "exec",
      "path": "../costrict-keeper",
      "version": "1.1.32",
      "platforms": [
        {
          "os": "windows",
          "arch": "amd64"
        },
        {
          "os": "linux",
          "arch": "amd64"
        },
        {
          "os": "linux",
          "arch": "arm64"
        },
        {
          "os": "darwin",
          "arch": "amd64"
        },
        {
          "os": "darwin",
          "arch": "arm64"
        }
      ],
      "description": "Costrict client process management service"
    },
    {
      "name": "cotun",
      "type": "exec",
      "path": "../cotun",
      "version": "1.3.10",
      "platforms": [
        {
          "os": "windows",
          "arch": "amd64"
        },
        {
          "os": "linux",
          "arch": "amd64"
        },
        {
          "os": "linux",
          "arch": "arm64"
        },
        {
          "os": "darwin",
          "arch": "amd64"
        },
        {
          "os": "darwin",
          "arch": "arm64"
        }
      ],
      "description": "Stream transfer tools"
    },
    {
      "name": "completion-agent",
      "type": "exec",
      "path": "../completion-agent",
      "version": "1.0.19",
      "platforms": [
        {
          "os": "windows",
          "arch": "amd64"
        },
        {
          "os": "linux",
          "arch": "amd64"
        },
        {
          "os": "linux",
          "arch": "arm64"
        },
        {
          "os": "darwin",
          "arch": "amd64"
        },
        {
          "os": "darwin",
          "arch": "arm64"
        }
      ],
      "description": "Client agent for code completion"
    },
    {
      "name": "costrict-admin",
      "type": "exec",
      "path": "../costrict-admin/backend",
      "platforms": [
        {
          "os": "windows",
          "arch": "amd64"
        },
        {
          "os": "linux",
          "arch": "amd64"
        }
      ],
      "version": "1.0.43",
      "description": "The back-end management of costrict"
    },
    {
      "name": "costrict-admin-backend",
      "type": "zip",
      "path": "./configures",
      "version": "1.0.45",
      "description": "The back-end docker-service of costrict"
    },
    {
      "name": "costrict-admin-frontend",
      "type": "zip",
      "path": "./configures",
      "version": "1.0.32",
      "description": "The front-end page of the costrict-admin service"
    },
    {
      "name": "system",
      "type": "conf",
      "path": "./configures",
      "target": "system-spec.json",
      "filename": "share/system-spec.json",
      "version": "1.1.5",
      "description": "Client Subsystem Definition File"
    },
    {
      "name": "firmware",
      "type": "zip",
      "path": "./configures",
      "version": "1.0.36",
      "description": "The firmware of the backend system"
    },
    {
      "name": "frontend",
      "type": "zip",
      "path": "./configures",
      "version": "1.0.4",
      "description": "Frontend Subsystem Definition File"
    },
    {
      "name": "backend",
