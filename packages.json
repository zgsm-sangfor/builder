      "path": "./configures",
      "version": "1.0.25",
      "description": "Backend Subsystem Definition File"
    },
    {
      "name": "costrict-config",
      "type": "conf",
      "path": "./configures",
      "target": "costrict.json",
      "filename": "config/costrict.json",
      "version": "1.1.4",
      "description": "Costrict configure file"
    },
    {
      "name": "cotun-options",
      "type": "conf",
      "path": "./configures",
      "target": "cotun-options.json",
      "filename": "config/cotun-options.json",
      "version": "1.0.0",
      "description": "Cotun option file"
    },
    {
      "name": "completion-config",
